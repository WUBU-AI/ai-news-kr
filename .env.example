# ============================================================
# AI 뉴스 큐레이션 사이트 — 환경변수 예시
# 실제 값은 .env.local 파일에 작성 (절대 커밋하지 말 것)
# ============================================================

# --- Supabase ---
# Supabase 프로젝트 > Settings > Database > Connection String (Transaction mode)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase 프로젝트 > Settings > Database > Connection String (Session mode / Direct)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# Supabase 프로젝트 > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"

# Supabase 프로젝트 > Settings > API > Project API Keys > anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase 프로젝트 > Settings > API > Project API Keys > service_role (서버사이드만 사용)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- OpenAI ---
# OpenAI 플랫폼 > API Keys
OPENAI_API_KEY="sk-..."

# --- RSS 수집 ---
# 수집 대상 RSS 피드 URL (쉼표 구분, 또는 settings 테이블에서 관리)
RSS_FEED_URLS="https://feeds.feedburner.com/oreilly/radar,https://www.artificialintelligence-news.com/feed/"

# --- Cron 보안 ---
# Vercel Cron Job 호출 시 검증용 시크릿 (임의의 강한 난수 문자열)
CRON_SECRET="your-random-secret-here"

# --- 앱 설정 ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NODE_ENV="development"
